# ---------------------------------------------------------------------------------------------------------------------
# REMOTE BACKEND — {{ environment | upper }}
# Project: {{ project_name }}
# Generated by tf-starter
# ---------------------------------------------------------------------------------------------------------------------

terraform {
  backend "s3" {
    ### MUST EDIT THIS ###
    bucket         = "{{ project_name }}-terraform-state"
    key            = "{{ project_name }}/{{ environment }}/terraform.tfstate"
    region         = "{{ region }}"
    encrypt        = true
    dynamodb_table = "{{ project_name }}-terraform-lock"
  }
}