# ---------------------------------------------------------------------------------------------------------------------
# API GATEWAY MODULE — Google Cloud API Gateway
# Project: {{ project_name }}
# Generated by tf-starter
# ---------------------------------------------------------------------------------------------------------------------

locals {
  name_prefix = "${var.project_name}-${var.environment}"
  api_id      = "${local.name_prefix}-api"
}

# ---------------------------------------------------------------------------------------------------------------------
# API GATEWAY API
# ---------------------------------------------------------------------------------------------------------------------

resource "google_api_gateway_api" "main" {
  provider = google-beta
  project  = var.project_id
  api_id   = local.api_id

  labels = var.labels
}

# ---------------------------------------------------------------------------------------------------------------------
# API CONFIG (OpenAPI spec)
# ---------------------------------------------------------------------------------------------------------------------

resource "google_api_gateway_api_config" "main" {
  provider      = google-beta
  project       = var.project_id
  api           = google_api_gateway_api.main.api_id
  api_config_id = "${local.api_id}-config"

  openapi_documents {
    document {
      path = "openapi.yaml"
      contents = base64encode(templatefile("${path.module}/openapi.yaml.tpl", {
        function_uri = var.function_uri
        project_id   = var.project_id
        api_title    = "${var.project_name} API"
      }))
    }
  }

  lifecycle {
    create_before_destroy = true
  }

  labels = var.labels

  ### MUST EDIT THIS ###
  # Customize the OpenAPI spec in openapi.yaml.tpl to define your API routes.
}

# ---------------------------------------------------------------------------------------------------------------------
# API GATEWAY (deployment)
# ---------------------------------------------------------------------------------------------------------------------

resource "google_api_gateway_gateway" "main" {
  provider   = google-beta
  project    = var.project_id
  region     = var.region
  api_config = google_api_gateway_api_config.main.id
  gateway_id = "${local.api_id}-gateway"

  labels = var.labels
}
