# ---------------------------------------------------------------------------------------------------------------------
# COMPUTE MODULE — Instance Template, MIG, HTTP(S) LB
# Generated by tf-starter
# ---------------------------------------------------------------------------------------------------------------------

locals {
  name_prefix = "${var.project_name}-${var.environment}"
}

data "google_compute_image" "debian" {
  family  = "debian-12"
  project = "debian-cloud"
}

resource "google_compute_instance_template" "main" {
  name_prefix  = "${local.name_prefix}-tmpl-"
  project      = var.project_id
  machine_type = var.machine_type
  region       = var.region

  disk {
    source_image = data.google_compute_image.debian.self_link
    auto_delete  = true
    boot         = true
    disk_size_gb = 20
  }

  network_interface {
    subnetwork = var.subnet_self_link
  }

  metadata_startup_script = <<-EOF
    #!/bin/bash
    ### MUST EDIT THIS ###
    echo "Instance initialized for ${local.name_prefix}"
  EOF

  tags = ["http-server"]

  labels = var.labels

  lifecycle {
    create_before_destroy = true
  }
}

resource "google_compute_health_check" "main" {
  name    = "${local.name_prefix}-hc"
  project = var.project_id

  http_health_check {
    port = 80
  }

  check_interval_sec  = 10
  timeout_sec         = 5
  healthy_threshold   = 3
  unhealthy_threshold = 3
}

resource "google_compute_region_instance_group_manager" "main" {
  name    = "${local.name_prefix}-mig"
  project = var.project_id
  region  = var.region

  base_instance_name = "${local.name_prefix}-vm"
  target_size        = var.target_size

  version {
    instance_template = google_compute_instance_template.main.id
  }

  named_port {
    name = "http"
    port = 80
  }

  auto_healing_policies {
    health_check      = google_compute_health_check.main.id
    initial_delay_sec = 300
  }
}

resource "google_compute_region_autoscaler" "main" {
  name    = "${local.name_prefix}-autoscaler"
  project = var.project_id
  region  = var.region
  target  = google_compute_region_instance_group_manager.main.id

  autoscaling_policy {
    min_replicas    = var.min_replicas
    max_replicas    = var.max_replicas
    cooldown_period = 60

    cpu_utilization {
      target = 0.8
    }
  }
}

resource "google_compute_global_address" "lb" {
  name    = "${local.name_prefix}-lb-ip"
  project = var.project_id
}

resource "google_compute_backend_service" "main" {
  name        = "${local.name_prefix}-backend"
  project     = var.project_id
  protocol    = "HTTP"
  port_name   = "http"
  timeout_sec = 30

  backend {
    group = google_compute_region_instance_group_manager.main.instance_group
  }

  health_checks = [google_compute_health_check.main.id]
}

resource "google_compute_url_map" "main" {
  name            = "${local.name_prefix}-url-map"
  project         = var.project_id
  default_service = google_compute_backend_service.main.id
}

resource "google_compute_target_http_proxy" "main" {
  name    = "${local.name_prefix}-http-proxy"
  project = var.project_id
  url_map = google_compute_url_map.main.id
}

resource "google_compute_global_forwarding_rule" "main" {
  name       = "${local.name_prefix}-fwd-rule"
  project    = var.project_id
  target     = google_compute_target_http_proxy.main.id
  port_range = "80"
  ip_address = google_compute_global_address.lb.address
}